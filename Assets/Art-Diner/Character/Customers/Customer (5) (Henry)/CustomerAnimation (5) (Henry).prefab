  m_Script: {fileID: 11500000, guid: 72ab146761a4fbf47943ea8d1345e932, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  commentText: There was a problem with hands appearing on top of the table when
    sitting/eating. Solution required attaching Sorting Group to the hands and adjusting
    the Z position to appear on top of the Animator
  commentIconType: 1
